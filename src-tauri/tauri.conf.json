{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GamingApp",
  "version": "0.1.0",
  "identifier": "com.gamingapp.app",
  "build": {
    "frontendDist": "../frontend/dist/gaming-app",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "cd ../frontend && npx ng build",
    "beforeBuildCommand": "cd ../frontend && npx ng build"
  },
  "app": {
    "windows": [
      {
        "title": "Game Stream",
        "width": 1280,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
